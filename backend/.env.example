APP_NAME="Naptech Factory OS API"
ENVIRONMENT="development"
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/naptech_factory_os"
SUPABASE_DATABASE_URL=""
JWT_SECRET_KEY="change-this-secret-before-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
ALLOWED_LOGIN_DOMAIN="naptech.in"
ALLOWED_LOGIN_EMAILS="inventory@naptech.in,production@naptech.in,quality@naptech.in"
